{
  "name": "synapseclean",
  "version": "1.1.1",
  "description": "Open-source local context compactor and semantic prompt cleaner for AI power-users.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fujiDevv/synapseclean.git"
  },
  "homepage": "https://github.com/fujiDevv/synapseclean",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "vitest run tests",
    "test:e2e": "bun run build && playwright test",
    "test:report": "playwright show-report",
    "dev": "vite build --watch",
    "build": "vite build && bun scripts/postbuild.mjs",
    "build:plain": "vite build",
    "logos": "python3 scripts/generate_logos.py",
    "package:store": "bash scripts/package-store.sh",
    "verify": "bun run type-check && bun run test && bun run build",
    "verify:ci": "bun run verify && bun run test:e2e"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.0.268",
    "@types/node": "^26.0.1",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}